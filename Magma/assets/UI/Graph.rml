<rml>
<head>
    <link type="text/rcss" href="style.rcss"/>
	<link type="text/rcss" href="Graph.rcss"/>
</head>

<body>
	<div id="graph-root">
		<div id="graph-canvas">
			<!-- Nodes injected dynamically -->
		</div>

		<div id="graph-overlay">
			<input type="range" id="zoom" min="0" max="1" step="0.01" value="0.4"/>
		</div>
	</div>
</body>
</rml>
